{
    "manifest_version": 3,
    "name": "PinTwist - Pinterest Analytics",
    "description": "Local-only Pinterest analytics with pin sorting, smart filtering, HD image downloads, and a local gallery.",
    "version": "1.0.2",
    "author": "iScaleLabs",
    "action": {
        "default_popup": "popup.html",
        "default_title": "PinTwist - Toggle Bar",
        "default_icon": {
            "16": "images/icon-16.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
        }
    },
    "icons": {
        "16": "images/icon-16.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.pinterest.at/*",
                "*://*.pinterest.ca/*",
                "*://*.pinterest.ch/*",
                "*://*.pinterest.cl/*",
                "*://*.pinterest.co.in/*",
                "*://*.pinterest.co.kr/*",
                "*://*.pinterest.co.nz/*",
                "*://*.pinterest.co.uk/*",
                "*://*.pinterest.com.au/*",
                "*://*.pinterest.com.mx/*",
                "*://*.pinterest.com/*",
                "*://*.pinterest.cz/*",
                "*://*.pinterest.de/*",
                "*://*.pinterest.dk/*",
                "*://*.pinterest.es/*",
                "*://*.pinterest.fi/*",
                "*://*.pinterest.fr/*",
                "*://*.pinterest.ie/*",
                "*://*.pinterest.it/*",
                "*://*.pinterest.jp/*",
                "*://*.pinterest.nl/*",
                "*://*.pinterest.nz/*",
                "*://*.pinterest.ph/*",
                "*://*.pinterest.pt/*",
                "*://*.pinterest.ru/*",
                "*://*.pinterest.se/*"
            ],
            "js": [
                "./js/pintwist-catalog-shared.js",
                "./js/content.js"
            ],
            "css": [
                "./css/style.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "./js/background.js"
    },
    "permissions": [
        "activeTab",
        "storage",
        "downloads",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "*://*.pinterest.com/*",
        "*://*.pinterest.at/*",
        "*://*.pinterest.ca/*",
        "*://*.pinterest.ch/*",
        "*://*.pinterest.cl/*",
        "*://*.pinterest.co.in/*",
        "*://*.pinterest.co.kr/*",
        "*://*.pinterest.co.nz/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.com.au/*",
        "*://*.pinterest.com.mx/*",
        "*://*.pinterest.cz/*",
        "*://*.pinterest.de/*",
        "*://*.pinterest.dk/*",
        "*://*.pinterest.es/*",
        "*://*.pinterest.fi/*",
        "*://*.pinterest.fr/*",
        "*://*.pinterest.ie/*",
        "*://*.pinterest.it/*",
        "*://*.pinterest.jp/*",
        "*://*.pinterest.nl/*",
        "*://*.pinterest.nz/*",
        "*://*.pinterest.ph/*",
        "*://*.pinterest.pt/*",
        "*://*.pinterest.ru/*",
        "*://*.pinterest.se/*",
        "*://*.pinimg.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "images/logo-icon.png",
                "images/logo-wordmark.png"
            ],
            "matches": [
                "*://*.pinterest.com/*",
                "*://*.pinterest.at/*",
                "*://*.pinterest.ca/*",
                "*://*.pinterest.ch/*",
                "*://*.pinterest.cl/*",
                "*://*.pinterest.co.in/*",
                "*://*.pinterest.co.kr/*",
                "*://*.pinterest.co.nz/*",
                "*://*.pinterest.co.uk/*",
                "*://*.pinterest.com.au/*",
                "*://*.pinterest.com.mx/*",
                "*://*.pinterest.cz/*",
                "*://*.pinterest.de/*",
                "*://*.pinterest.dk/*",
                "*://*.pinterest.es/*",
                "*://*.pinterest.fi/*",
                "*://*.pinterest.fr/*",
                "*://*.pinterest.ie/*",
                "*://*.pinterest.it/*",
                "*://*.pinterest.jp/*",
                "*://*.pinterest.nl/*",
                "*://*.pinterest.nz/*",
                "*://*.pinterest.ph/*",
                "*://*.pinterest.pt/*",
                "*://*.pinterest.ru/*",
                "*://*.pinterest.se/*",
                "*://*.pinimg.com/*"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "version_name": "1.0.2"
}
